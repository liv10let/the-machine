# ActivityWatch 飞书日历守卫环境变量配置
# 复制为 .env 并填写真实值

# 飞书机器人配置（用于发送分心提醒卡片）
THE_MACHINE_FEISHU_APP_ID=cli_xxx
THE_MACHINE_FEISHU_APP_SECRET=your-app-secret
THE_MACHINE_FEISHU_CHAT_ID=oc_xxx

# lark-cli 日历 ID（主日历）
THE_MACHINE_CALENDAR_ID=feishu.cn_xxx@group.calendar.feishu.cn

# ActivityWatch 服务器地址和认证
THE_MACHINE_AW_API_BASE=http://localhost:5600/api/0
THE_MACHINE_AW_AUTH=awuser:awpass

# lark-cli 可执行文件路径（自动探测失败时手动指定）
# THE_MACHINE_LARK_CLI=/usr/local/bin/lark-cli
